{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22",
    "pnpm": "10"
  },
  "steps": {
    "install": {
      "commands": ["pip install -r requirements.txt"]
    },
    "build": {
      "commands": ["pnpm install --frozen-lockfile", "pnpm --filter @workspace/youtube-feed build"]
    }
  }
}
